<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        DictateFlow vector icon set.

        Glyphs are Fluent System Icons (https://github.com/microsoft/fluentui-system-icons,
        MIT) — the same set surfaced by https://fluenticons.co — taken from the 24px
        "regular" variants, so every geometry lives in a 0 0 24 24 coordinate space.

        These replace the raster PNGs (Resources/*.png) History used to reference: vector
        geometry stays crisp at any DPI and tints with the theme instead of being baked to
        one colour.

        Usage — a themed, self-tinting glyph:

            <Path Style="{StaticResource FluentIcon}" Data="{StaticResource Icon.Copy}" />

        The FluentIcon style binds Fill to the inherited TextElement.Foreground, so a glyph
        placed inside a Button/ListBoxItem/etc. automatically follows that container's
        Foreground — including hover/pressed/disabled colour changes. Override Width/Height
        inline for a larger glyph (default is 16x16); set Fill inline to pin a colour.

        Each geometry string is prefixed with "F1" to select the nonzero fill rule (SVG's
        default). WPF Geometry parsing defaults to EvenOdd, which would punch out the wrong
        counters on several of these icons — keep the F1.
    -->

    <!-- ===== Reusable presenter ===== -->
    <Style x:Key="FluentIcon" TargetType="{x:Type Path}">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <!-- Follow the inherited text colour of whatever hosts the glyph. -->
        <Setter Property="Fill"
                Value="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource Self}}" />
    </Style>

