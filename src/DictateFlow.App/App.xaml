<Application x:Class="DictateFlow.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tray="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <tray:TaskbarIcon x:Key="TrayIcon"
                              ToolTipText="DictateFlow"
                              IconSource="/Resources/appicon.ico">
                <tray:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Dictate" Command="{Binding DictateCommand}" />
                        <MenuItem Header="Prompt Mode" ItemsSource="{Binding PromptModes}">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                    <Setter Property="Header" Value="{Binding Name}" />
                                    <Setter Property="ToolTip" Value="{Binding Description}" />
                                    <Setter Property="Command" Value="{Binding SelectCommand}" />
                                    <Setter Property="IsCheckable" Value="False" />
                                    <Setter Property="IsChecked" Value="{Binding IsActive, Mode=OneWay}" />
                                </Style>
                            </MenuItem.ItemContainerStyle>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}" />
                        <MenuItem Header="History" Command="{Binding OpenHistoryCommand}" />
                        <MenuItem Header="Cost Dashboard" Command="{Binding OpenCostDashboardCommand}" />
                        <Separator />
                        <MenuItem Header="Check for Updates…" Command="{Binding CheckForUpdatesCommand}" />
                        <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
                    </ContextMenu>
                </tray:TaskbarIcon.ContextMenu>
            </tray:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>
