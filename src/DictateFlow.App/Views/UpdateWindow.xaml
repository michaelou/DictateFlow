<Window x:Class="DictateFlow.App.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource WindowBackgroundBrush}"
        Title="DictateFlow Updates"
        Width="460"
        Height="420"
        MinWidth="380"
        MinHeight="260"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,12"
                   FontSize="16"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Text="{Binding Headline}" />

        <TextBlock Grid.Row="1"
                   Margin="0,0,0,2"
                   Text="{Binding CurrentVersionText}" />

        <TextBlock Grid.Row="2"
                   Margin="0,0,0,8"
                   Visibility="{Binding HasLatestVersion, Converter={StaticResource BoolToVis}}"
                   Text="{Binding LatestVersionText}" />

        <TextBlock Grid.Row="3"
                   Margin="0,4,0,4"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   TextWrapping="Wrap"
                   Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}"
                   Text="{Binding StatusMessage}" />

        <Border Grid.Row="4"
                Margin="0,4,0,0"
                BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1"
                Visibility="{Binding HasReleaseNotes, Converter={StaticResource BoolToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <TextBox Background="Transparent"
                         BorderThickness="0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Disabled"
                         Text="{Binding ReleaseNotes, Mode=OneWay}" />
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="5" Margin="0,12,0,0">
            <StackPanel Margin="0,0,0,8"
                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                <ProgressBar Height="6"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding DownloadProgress}" />
            </StackPanel>

            <TextBlock Margin="0,0,0,8"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       TextWrapping="Wrap"
                       Visibility="{Binding HasDownloadStatus, Converter={StaticResource BoolToVis}}"
                       Text="{Binding DownloadStatus}" />

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Width="170"
                        Margin="0,0,8,0"
                        Content="Download &amp; install"
                        Command="{Binding DownloadAndInstallCommand}"
                        Visibility="{Binding CanDownloadInstall, Converter={StaticResource BoolToVis}}" />
                <Button Width="150"
                        Margin="0,0,8,0"
                        Content="Open release page"
                        Command="{Binding OpenReleasePageCommand}"
                        Visibility="{Binding HasReleaseUrl, Converter={StaticResource BoolToVis}}" />
                <Button Width="88"
                        Content="Close"
                        IsCancel="True"
                        Command="{Binding CloseCommand}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
