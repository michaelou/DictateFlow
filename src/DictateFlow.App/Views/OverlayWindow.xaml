<Window x:Class="DictateFlow.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:DictateFlow.Core.Models;assembly=DictateFlow.Core"
        Title="DictateFlow Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False">
    <Border Padding="14,9"
            Background="#DD202020"
            CornerRadius="10"
            IsHitTestVisible="False">
        <StackPanel Orientation="Vertical">
            <!-- Prompt mode selected for this dictation, shown above the status line. -->
            <TextBlock FontSize="11"
                       Foreground="#FF7FB8FF"
                       MaxWidth="420"
                       Margin="0,0,0,3"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding PromptMode, Mode=OneWay}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasPromptMode}" Value="True" />
                                    <Condition Binding="{Binding State}" Value="{x:Static models:OverlayState.Listening}" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasPromptMode}" Value="True" />
                                    <Condition Binding="{Binding State}" Value="{x:Static models:OverlayState.Processing}" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="14"
                           Foreground="White"
                           MaxWidth="420"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="🎤 Listening…" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:OverlayState.Processing}">
                                    <Setter Property="Text" Value="🧠 Processing…" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:OverlayState.Success}">
                                    <Setter Property="Text" Value="✓ Pasted" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:OverlayState.Error}">
                                    <Setter Property="Text" Value="{Binding ErrorDisplayText}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ProgressBar Width="90"
                             Height="6"
                             Margin="12,0,0,0"
                             Minimum="0"
                             Maximum="1"
                             Value="{Binding Level, Mode=OneWay}"
                             BorderThickness="0"
                             Background="#33FFFFFF"
                             Foreground="#FF4CC38A"
                             VerticalAlignment="Center">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:OverlayState.Listening}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
            </StackPanel>
            <!-- Partial transcript from streaming transcription, shown only while listening. -->
            <TextBlock FontSize="12"
                       Foreground="#CCFFFFFF"
                       MaxWidth="420"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       Text="{Binding PartialTranscriptDisplay, Mode=OneWay}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding State}" Value="{x:Static models:OverlayState.Listening}" />
                                    <Condition Binding="{Binding HasPartialTranscript}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Border>
</Window>
