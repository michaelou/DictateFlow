<Window x:Class="DictateFlow.App.Views.CommandConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource WindowBackgroundBrush}"
        Title="Execute command?"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    <Border Padding="20" MinWidth="320">
        <StackPanel>
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Text="Execute command?" />
            <TextBlock Margin="0,10,0,0"
                       MaxWidth="360"
                       TextWrapping="Wrap"
                       Text="{Binding CommandName, Mode=OneWay}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="{Binding TimeoutNotice, Mode=OneWay}" />
            <StackPanel Margin="0,18,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button x:Name="YesButton"
                        Width="88"
                        Content="_Yes"
                        IsDefault="True"
                        Click="OnYes" />
                <!-- IsCancel makes No (and Escape) close the dialog with DialogResult = false. -->
                <Button Width="88"
                        Margin="8,0,0,0"
                        Content="_No"
                        IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
