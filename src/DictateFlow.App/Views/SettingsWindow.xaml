<Window x:Class="DictateFlow.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DictateFlow.App.Controls"
        Background="{DynamicResource WindowBackgroundBrush}"
        Title="DictateFlow Settings"
        Width="640"
        Height="440"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Shows the item's Name in the closed selection box as well as the drop-down.
             DisplayMemberPath alone leaves the themed ComboBox's SelectionBoxItemTemplate
             null, so the closed box would fall back to the item's ToString(). -->
        <DataTemplate x:Key="NameItemTemplate">
            <TextBlock Text="{Binding Name}" />
        </DataTemplate>
        <DataTemplate x:Key="DisplayNameItemTemplate">
            <TextBlock Text="{Binding DisplayName}" />
        </DataTemplate>

        <controls:SectionIconConverter x:Key="SectionIcon" />

        <!-- Base style for a settings page: hidden until its section is selected, and it
             fades in each time it becomes visible (the per-section DataTrigger that flips
             Visibility to Visible is added by each page's own BasedOn style). -->
        <Style x:Key="SectionPage" TargetType="{x:Type StackPanel}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <Trigger Property="IsVisible" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Nav rail item: icon + label with an accent bar that grows in on selection. -->
        <DataTemplate x:Key="NavItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Path Style="{StaticResource FluentIcon}" Width="16" Height="16" Data="{Binding Converter={StaticResource SectionIcon}}" />
                <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="{Binding}" />
            </Grid>
        </DataTemplate>

        <Style x:Key="NavItem" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Grid Margin="0,1">
                            <Border x:Name="bg"
                                    Background="Transparent"
                                    CornerRadius="{StaticResource ControlCornerRadius}"
                                    Padding="10,7">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="activebar"
                                    Width="3"
                                    Height="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    CornerRadius="2"
                                    Background="{StaticResource AccentBrush}"
                                    Opacity="0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="barScale" ScaleY="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource ControlHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource SurfaceElevatedHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="barScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="activebar" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="barScale" Storyboard.TargetProperty="ScaleY" To="0" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="activebar" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0"
              Grid.Column="0"
              Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ListBox Grid.Row="0"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource NavItem}"
                     ItemTemplate="{StaticResource NavItemTemplate}"
                     ItemsSource="{Binding Sections}"
                     SelectedItem="{Binding SelectedSection}" />

            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                <Separator Margin="0,0,0,4" />
                <Button Margin="0,2,0,0"
                        HorizontalContentAlignment="Left"
                        Command="{Binding ShowHistoryCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource FluentIcon}" Width="15" Height="15" Data="{StaticResource Icon.History}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Show History" />
                    </StackPanel>
                </Button>
                <Button Margin="0,2,0,0"
                        HorizontalContentAlignment="Left"
                        Command="{Binding ShowCostDashboardCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource FluentIcon}" Width="15" Height="15" Data="{StaticResource Icon.Money}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Show Cost Dashboard" />
                    </StackPanel>
                </Button>
                <Button Margin="0,2,0,0"
                        HorizontalContentAlignment="Left"
                        Command="{Binding CheckForUpdatesCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource FluentIcon}" Width="15" Height="15" Data="{StaticResource Icon.Download}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Check for Updates…" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="0"
                Grid.Column="1"
                Background="{StaticResource SurfaceElevatedBrush}"
                BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CardCornerRadius}"
                Padding="16"
                Effect="{StaticResource CardShadow}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- General / Recording page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="General">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Recording" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Push-to-talk hotkey (hold to talk)" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="PushToTalkHotkeyBox"
                                 Width="200"
                                 HorizontalAlignment="Left"
                                 IsReadOnly="True"
                                 IsReadOnlyCaretVisible="False"
                                 Text="{Binding PushToTalkHotkey, Mode=OneWay}"
                                 PreviewKeyDown="OnPushToTalkHotkeyPreviewKeyDown"
                                 PreviewKeyUp="OnPushToTalkHotkeyPreviewKeyUp" />
                        <Button Margin="8,0,0,0"
                                Padding="8,0"
                                Content="Clear"
                                Command="{Binding ClearPushToTalkHotkeyCommand}" />
                    </StackPanel>

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Toggle hotkey (press to start/stop)" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="ToggleHotkeyBox"
                                 Width="200"
                                 HorizontalAlignment="Left"
                                 IsReadOnly="True"
                                 IsReadOnlyCaretVisible="False"
                                 Text="{Binding ToggleHotkey, Mode=OneWay}"
                                 PreviewKeyDown="OnToggleHotkeyPreviewKeyDown"
                                 PreviewKeyUp="OnToggleHotkeyPreviewKeyUp" />
                        <Button Margin="8,0,0,0"
                                Padding="8,0"
                                Content="Clear"
                                Command="{Binding ClearToggleHotkeyCommand}" />
                    </StackPanel>

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="DictatePad hotkey (open the scratchpad)" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="DictatePadHotkeyBox"
                                 Width="200"
                                 HorizontalAlignment="Left"
                                 IsReadOnly="True"
                                 IsReadOnlyCaretVisible="False"
                                 Text="{Binding DictatePadHotkey, Mode=OneWay}"
                                 PreviewKeyDown="OnDictatePadHotkeyPreviewKeyDown"
                                 PreviewKeyUp="OnDictatePadHotkeyPreviewKeyUp" />
                        <Button Margin="8,0,0,0"
                                Padding="8,0"
                                Content="Clear"
                                Command="{Binding ClearDictatePadHotkeyCommand}" />
                    </StackPanel>
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               Text="Click a box and press the desired key combination — including modifier-only chords like Ctrl+Win or RCtrl+RShift. Leave a box empty (Clear) to disable that trigger." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Microphone" />
                    <ComboBox Width="280"
                              HorizontalAlignment="Left"
                              ItemTemplate="{StaticResource DisplayNameItemTemplate}"
                              ItemsSource="{Binding Microphones}"
                              SelectedItem="{Binding SelectedMicrophone}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Silence timeout (seconds)" />
                    <TextBox Width="80"
                             HorizontalAlignment="Left"
                             Text="{Binding SilenceTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />

                    <CheckBox Margin="0,12,0,0"
                              Content="Enable _streaming transcription"
                              IsChecked="{Binding EnableStreamingTranscription}" />
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               TextWrapping="Wrap"
                               Text="Transcribes while you speak and shows the live transcript on the overlay. Only applies when the active speech provider supports streaming; otherwise the standard workflow runs." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Log level" />
                    <ComboBox Width="160"
                              HorizontalAlignment="Left"
                              ItemsSource="{Binding LogLevels}"
                              SelectedItem="{Binding SelectedLogLevel}" />
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               Text="Debug writes per-dictation latency details to the log files. Takes effect after a restart." />

                    <TextBlock Margin="0,16,0,4" FontSize="15" FontWeight="SemiBold" Text="Startup" />
                    <CheckBox Margin="0,4,0,0"
                              Content="_Launch DictateFlow when Windows starts"
                              IsChecked="{Binding LaunchAtStartup}" />
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               Text="Adds a per-user entry under the Windows Run registry key. Applied when you Save." />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationError}" />
                </StackPanel>

                <!-- Speech (transcription provider) page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Speech">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Speech recognition" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="The provider that turns recordings into text. The Mock provider returns canned text, so the whole flow works without any cloud service." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Provider" />
                    <ComboBox Width="200"
                              HorizontalAlignment="Left"
                              ItemsSource="{Binding SpeechProviders}"
                              SelectedItem="{Binding SelectedSpeechProvider}" />

                    <!-- AzureFoundry config section -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSpeechProvider}" Value="AzureFoundry">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Endpoint" />
                        <TextBox Width="340"
                                 HorizontalAlignment="Left"
                                 Text="{Binding SpeechEndpoint, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="API key" />
                        <PasswordBox Width="340"
                                     HorizontalAlignment="Left"
                                     controls:PasswordBoxHelper.BoundPassword="{Binding SpeechApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Deployment name" />
                        <TextBox Width="200"
                                 HorizontalAlignment="Left"
                                 Text="{Binding SpeechDeploymentName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Languages" />
                        <TextBox Width="340"
                                 HorizontalAlignment="Left"
                                 Text="{Binding SpeechLanguage, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,4,0,0"
                                   Width="340"
                                   HorizontalAlignment="Left"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="Comma-separated locales, e.g. en-US, el-GR; leave empty for auto-detect. The standard model limits language detection to the listed locales; the enhanced model (deployment name set) is multilingual and auto-detects whenever more than one is listed." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Timeout (seconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding SpeechTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Azure Speech (real-time, streaming-capable) config section -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSpeechProvider}" Value="AzureSpeech">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="Azure real-time speech-to-text. Supports streaming transcription (live transcript while you speak) when it is enabled on the General page." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Endpoint" />
                        <TextBox Width="340"
                                 HorizontalAlignment="Left"
                                 Text="{Binding AzureSpeechEndpoint, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,4,0,0"
                                   Width="340"
                                   HorizontalAlignment="Left"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="The Speech/AI Foundry resource endpoint, e.g. https://myresource.cognitiveservices.azure.com/ — the same endpoint the AzureFoundry provider uses." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="API key" />
                        <PasswordBox Width="340"
                                     HorizontalAlignment="Left"
                                     controls:PasswordBoxHelper.BoundPassword="{Binding AzureSpeechApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Languages" />
                        <TextBox Width="340"
                                 HorizontalAlignment="Left"
                                 Text="{Binding AzureSpeechLanguage, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,4,0,0"
                                   Width="340"
                                   HorizontalAlignment="Left"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="Comma-separated locales, e.g. en-US, el-GR. One locale pins the language; several enable continuous language detection restricted to them; empty uses the service default (en-US)." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Timeout (seconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding AzureSpeechTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,4,0,0"
                                   Width="340"
                                   HorizontalAlignment="Left"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="Applies to whole-capture transcription only; streaming sessions last as long as the recording." />
                    </StackPanel>

                    <!-- OpenRouter config section -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSpeechProvider}" Value="OpenRouter">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Margin="0,12,0,0"
                                   Width="340"
                                   HorizontalAlignment="Left"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="OpenRouter has no dedicated speech-to-text endpoint, so audio is sent to an audio-capable chat model to transcribe. The model must accept audio input (e.g. google/gemini-2.5-flash, openai/gpt-4o-audio-preview)." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="API key" />
                        <PasswordBox Width="340"
                                     HorizontalAlignment="Left"
                                     controls:PasswordBoxHelper.BoundPassword="{Binding OpenRouterSpeechApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Model" />
                        <TextBox Width="240"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OpenRouterSpeechModel, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Language (optional)" />
                        <TextBox Width="200"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OpenRouterSpeechLanguage, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,4,0,0"
                                   Width="340"
                                   HorizontalAlignment="Left"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="A BCP-47 tag such as en-US, added as a hint to the transcription instruction; leave empty to let the model detect the language." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Timeout (seconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OpenRouterSpeechTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Mock config section -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSpeechProvider}" Value="Mock">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Delay (milliseconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding MockSpeechDelayMs, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Canned transcript" />
                        <TextBox Height="60"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding MockSpeechText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Local Whisper.cpp config section -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSpeechProvider}" Value="WhisperCpp">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   Text="{Binding WhisperStatusText}" />
                        <Button Width="160"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Content="Manage local models…"
                                Command="{Binding OpenLocalModelsCommand}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Model" />
                        <ComboBox Width="200"
                                  HorizontalAlignment="Left"
                                  ItemTemplate="{StaticResource DisplayNameItemTemplate}"
                                  ItemsSource="{Binding WhisperModels}"
                                  SelectedItem="{Binding SelectedWhisperModel}" />
                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0"
                                   TextWrapping="Wrap"
                                   Text="Small is the recommended default (fast, low memory); Medium is more accurate for multilingual and longer dictation but slower." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Language" />
                        <TextBox Width="200"
                                 HorizontalAlignment="Left"
                                 Text="{Binding WhisperLanguage, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0"
                                   Width="340"
                                   HorizontalAlignment="Left"
                                   TextWrapping="Wrap"
                                   Text="One locale, e.g. en or el-GR (only the language part is used); leave empty for auto-detect, which also handles mixed-language dictation." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Timeout (seconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding WhisperTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Local Parakeet config section -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSpeechProvider}" Value="Parakeet">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="NVIDIA Parakeet TDT 0.6B v3 running locally through the bundled sherpa-onnx runtime — fast, fully offline, multilingual (25 European languages, auto-detected)." />

                        <TextBlock Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   Text="{Binding ParakeetStatusText}" />
                        <Button Width="160"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Content="Manage local models…"
                                Command="{Binding OpenLocalModelsCommand}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Timeout (seconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding ParakeetTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <Button Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButton}"
                            Content="Test connection"
                            Command="{Binding TestConnectionCommand}" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding SpeechTestResult}" />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationError}" />
                </StackPanel>

                <!-- Local Models (whisper.cpp engine and model manager) page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Local Models">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Local models" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="The engines and models used by the local speech providers (Whisper.cpp and Parakeet) — fully offline transcription. Downloads are verified (SHA-256) and usable immediately, no restart needed." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Speech engines" />
                    <TextBlock Text="{Binding WhisperEngineStatus}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding ParakeetEngineStatus}" />

                    <TextBlock Margin="0,16,0,4" FontWeight="SemiBold" Text="Components" />
                    <ItemsControl ItemsSource="{Binding LocalModels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Width="80"
                                                    Content="Download"
                                                    Command="{Binding DataContext.DownloadLocalModelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsInstalled}" Value="False" />
                                                                    <Condition Binding="{Binding IsBusy}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Width="66"
                                                    Content="Cancel"
                                                    Command="{Binding DataContext.CancelLocalModelDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsInstalled}" Value="True" />
                                                                    <Condition Binding="{Binding IsBusy}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Button Width="56"
                                                        Content="Verify"
                                                        Command="{Binding DataContext.VerifyLocalModelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Width="56"
                                                        Margin="6,0,0,0"
                                                        Content="Delete"
                                                        Command="{Binding DataContext.DeleteLocalModelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                            <TextBlock Margin="8,0,8,0"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Text="{Binding StatusText}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <StackPanel Margin="0,6,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ProgressText}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <ProgressBar Height="8"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding ProgressPercent, Mode=OneWay}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Text="{Binding ProgressText}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Text="{Binding ActionResult}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Files are stored under your local app data folder (Engines and Models). Deleting a component frees the disk space; DictateFlow offers to download it again when needed." />
                </StackPanel>

                <!-- LLM (enhancement provider) page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="LLM">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="LLM enhancement" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="The provider that turns raw transcripts into polished text. The Mock provider prefixes the transcript, so the whole flow works without any cloud service." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Provider" />
                    <ComboBox Width="200"
                              HorizontalAlignment="Left"
                              ItemsSource="{Binding LlmProviders}"
                              SelectedItem="{Binding SelectedLlmProvider}" />

                    <!-- AzureFoundry config section -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLlmProvider}" Value="AzureFoundry">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Endpoint" />
                        <TextBox Width="340"
                                 HorizontalAlignment="Left"
                                 Text="{Binding LlmEndpoint, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="API key" />
                        <PasswordBox Width="340"
                                     HorizontalAlignment="Left"
                                     controls:PasswordBoxHelper.BoundPassword="{Binding LlmApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Deployment name" />
                        <TextBox Width="200"
                                 HorizontalAlignment="Left"
                                 Text="{Binding LlmDeploymentName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Temperature (0–2)" />
                        <StackPanel Orientation="Horizontal">
                            <Slider Width="220"
                                    VerticalAlignment="Center"
                                    Minimum="0"
                                    Maximum="2"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding LlmTemperature}" />
                            <TextBox Width="60"
                                     Margin="8,0,0,0"
                                     Text="{Binding LlmTemperature, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0"
                                   Text="Default for modes without their own temperature." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Max tokens" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding LlmMaxTokens, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Timeout (seconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding LlmTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Anthropic config section -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLlmProvider}" Value="Anthropic">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="Claude via the Anthropic API. Get a key at console.anthropic.com; claude-opus-4-8 is the most capable model, claude-haiku-4-5 the fastest and cheapest." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="API key" />
                        <PasswordBox Width="340"
                                     HorizontalAlignment="Left"
                                     controls:PasswordBoxHelper.BoundPassword="{Binding AnthropicApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Model" />
                        <TextBox Width="200"
                                 HorizontalAlignment="Left"
                                 Text="{Binding AnthropicModel, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Temperature (0–1)" />
                        <StackPanel Orientation="Horizontal">
                            <Slider Width="220"
                                    VerticalAlignment="Center"
                                    Minimum="0"
                                    Maximum="1"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding AnthropicTemperature}" />
                            <TextBox Width="60"
                                     Margin="8,0,0,0"
                                     Text="{Binding AnthropicTemperature, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0"
                                   TextWrapping="Wrap"
                                   Text="Default for modes without their own temperature. Current Claude models fix the temperature; the provider adapts automatically." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Max tokens" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding AnthropicMaxTokens, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Timeout (seconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding AnthropicTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Ollama config section -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLlmProvider}" Value="Ollama">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="A local Ollama server (default) or Ollama Cloud. The model must be pulled first (ollama pull &lt;model&gt;); for Ollama Cloud set the base URL to https://ollama.com and enter an API key." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Base URL" />
                        <TextBox Width="340"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OllamaBaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="API key (optional)" />
                        <PasswordBox Width="340"
                                     HorizontalAlignment="Left"
                                     controls:PasswordBoxHelper.BoundPassword="{Binding OllamaApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0"
                                   Text="Leave empty for a local server; required for Ollama Cloud." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Model" />
                        <TextBox Width="200"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OllamaModel, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Temperature (0–2)" />
                        <StackPanel Orientation="Horizontal">
                            <Slider Width="220"
                                    VerticalAlignment="Center"
                                    Minimum="0"
                                    Maximum="2"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding OllamaTemperature}" />
                            <TextBox Width="60"
                                     Margin="8,0,0,0"
                                     Text="{Binding OllamaTemperature, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0"
                                   Text="Default for modes without their own temperature." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Max tokens" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OllamaMaxTokens, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Timeout (seconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OllamaTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- OpenRouter config section -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLlmProvider}" Value="OpenRouter">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="One API key for models from many providers, routed through OpenRouter. Get a key at openrouter.ai/keys and pick a model slug from openrouter.ai/models (e.g. openai/gpt-4o-mini, anthropic/claude-sonnet-4)." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="API key" />
                        <PasswordBox Width="340"
                                     HorizontalAlignment="Left"
                                     controls:PasswordBoxHelper.BoundPassword="{Binding OpenRouterApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Model" />
                        <TextBox Width="240"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OpenRouterModel, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Temperature (0–2)" />
                        <StackPanel Orientation="Horizontal">
                            <Slider Width="220"
                                    VerticalAlignment="Center"
                                    Minimum="0"
                                    Maximum="2"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding OpenRouterTemperature}" />
                            <TextBox Width="60"
                                     Margin="8,0,0,0"
                                     Text="{Binding OpenRouterTemperature, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0"
                                   TextWrapping="Wrap"
                                   Text="Default for modes without their own temperature. Reasoning models that fix the temperature are handled automatically." />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Max tokens" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OpenRouterMaxTokens, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Timeout (seconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OpenRouterTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Mock config section -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLlmProvider}" Value="Mock">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Delay (milliseconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding MockLlmDelayMs, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <Button Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButton}"
                            Content="Test connection"
                            Command="{Binding TestLlmConnectionCommand}" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding LlmTestResult}" />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationError}" />
                </StackPanel>

                <!-- Prompts page: loaded modes, active-mode selector, and the Prompt Tester -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Prompts">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Prompt modes" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Each mode is a JSON file in the prompts folder. Edit modes here, or edit the files externally and Reload to pick them up." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Active mode" />
                    <ComboBox Width="220"
                              HorizontalAlignment="Left"
                              ItemTemplate="{StaticResource NameItemTemplate}"
                              ItemsSource="{Binding PromptModes}"
                              SelectedItem="{Binding SelectedPromptMode}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Loaded modes" />
                    <ItemsControl ItemsSource="{Binding PromptModes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,6">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Width="56"
                                                Content="Edit"
                                                Command="{Binding DataContext.EditPromptModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                        <Button Width="56"
                                                Margin="6,0,0,0"
                                                Content="Delete"
                                                Command="{Binding DataContext.DeletePromptModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock Margin="6,0,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Text="(LLM off)">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LlmEnabled}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Margin="8,0,8,0"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Description}" />
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <Button Width="88"
                                Content="New mode"
                                Command="{Binding NewPromptModeCommand}" />
                        <Button Width="88"
                                Margin="8,0,0,0"
                                Content="Reload"
                                Command="{Binding ReloadPromptsCommand}" />
                        <Button Width="140"
                                Margin="8,0,0,0"
                                Content="Open prompts folder"
                                Command="{Binding OpenPromptsFolderCommand}" />
                    </StackPanel>

                    <Separator Margin="0,16,0,8" />

                    <TextBlock FontSize="15"
                               FontWeight="SemiBold"
                               Text="Prompt Tester" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Paste a transcript and run it through the resolver and LLM — no recording needed." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Transcript" />
                    <TextBox Height="70"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding TesterTranscript, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <ComboBox Width="180"
                                  VerticalAlignment="Center"
                                  ItemTemplate="{StaticResource NameItemTemplate}"
                                  ItemsSource="{Binding PromptModes}"
                                  SelectedItem="{Binding TesterMode}" />
                        <Button Width="88"
                                Margin="8,0,0,0"
                                Content="Run"
                                Command="{Binding RunTesterCommand}" />
                        <Button Width="88"
                                Margin="8,0,0,0"
                                Content="Cancel"
                                Command="{Binding RunTesterCancelCommand}" />
                    </StackPanel>

                    <Expander Margin="0,8,0,0" Header="Resolved system prompt">
                        <TextBox MaxHeight="120"
                                 Margin="0,4,0,0"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding TesterResolvedPrompt, Mode=OneWay}" />
                    </Expander>

                    <TextBlock Margin="0,8,0,4" FontWeight="SemiBold" Text="Result" />
                    <TextBox Height="90"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding TesterResult, Mode=OneWay}" />
                </StackPanel>

                <!-- Output (text delivery) page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Output">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Output" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="How dictated text is delivered into the application that had focus. Changes apply from the next dictation." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Provider" />
                    <ComboBox Width="220"
                              HorizontalAlignment="Left"
                              ItemsSource="{Binding OutputProviders}"
                              SelectedItem="{Binding SelectedOutputProvider}" />
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               TextWrapping="Wrap"
                               Text="ClipboardPaste is fast (briefly replaces the clipboard, then restores it); SimulatedKeyboard types the text and works where paste is blocked." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Mode" />
                    <RadioButton Content="Automatic (deliver immediately after enhancement)"
                                 GroupName="OutputMode"
                                 IsChecked="{Binding IsAutomaticOutput}" />
                    <RadioButton Margin="0,4,0,0"
                                 Content="Preview (review and edit in a dialog before delivery)"
                                 GroupName="OutputMode"
                                 IsChecked="{Binding IsPreviewOutput}" />
                </StackPanel>

                <!-- Voice Commands page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Voice Commands">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Voice Commands" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Say the wake phrase followed by a command (e.g. “Hey John, open Settings”) to run it instead of dictating. Changes apply immediately after Save." />

                    <CheckBox Margin="0,12,0,0"
                              Content="_Enable voice commands"
                              IsChecked="{Binding VoiceCommandsEnabled}" />

                    <!-- Everything below is disabled while the master toggle is off. -->
                    <StackPanel Margin="0,4,0,0" IsEnabled="{Binding VoiceCommandsEnabled}">
                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Wake phrase" />
                        <TextBox Width="220"
                                 HorizontalAlignment="Left"
                                 Text="{Binding VoiceWakePhrase, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Margin="0,8,0,0"
                                  Content="Require the _wake phrase (when off, any utterance is checked against the command phrases)"
                                  IsChecked="{Binding VoiceWakePhraseEnabled}" />

                        <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Command timeout (seconds)" />
                        <TextBox Width="80"
                                 HorizontalAlignment="Left"
                                 Text="{Binding VoiceCommandTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox Margin="0,12,0,0"
                                  Content="Require _confirmation before every command runs"
                                  IsChecked="{Binding VoiceRequireConfirmation}" />
                        <CheckBox Margin="0,8,0,0"
                                  Content="Play command _sounds (recognized, success, failure)"
                                  IsChecked="{Binding VoiceEnableSounds}" />

                        <TextBlock Margin="0,16,0,6" FontWeight="SemiBold" Text="Commands" />

                        <!-- Elevated command panel: search, the (filterable) list, and CRUD actions. -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource SurfaceBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  Direction="270"
                                                  ShadowDepth="2"
                                                  Opacity="0.5"
                                                  Color="Black" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"
                                           Text="Built-in commands plus any JSON files in the commands folder. “arg” marks commands that use the spoken words after the phrase. Only your own commands can be edited or deleted." />

                                <!-- Search / filter -->
                                <Grid Margin="0,0,0,8">
                                    <TextBox x:Name="CommandFilterBox"
                                             Text="{Binding CommandFilter, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="6,0,0,0"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Search commands by name, phrase or action…">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CommandFilter}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <ItemsControl MaxHeight="220" ItemsSource="{Binding CommandsView}">
                                    <ItemsControl.Template>
                                        <ControlTemplate TargetType="ItemsControl">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </ControlTemplate>
                                    </ItemsControl.Template>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,0,0,8">
                                                <!-- Edit / Delete only for the user's own commands. -->
                                                <StackPanel DockPanel.Dock="Right"
                                                            VerticalAlignment="Center"
                                                            Orientation="Horizontal">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUserCommand}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Button Width="52"
                                                            Margin="8,0,0,0"
                                                            Content="Edit"
                                                            Command="{Binding DataContext.EditVoiceCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Width="56"
                                                            Margin="6,0,0,0"
                                                            Content="Delete"
                                                            Command="{Binding DataContext.DeleteVoiceCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                                <Border DockPanel.Dock="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,0,0"
                                                        Padding="5,1"
                                                        Background="{StaticResource AccentBrush}"
                                                        CornerRadius="3">
                                                    <TextBlock FontSize="10"
                                                               Foreground="White"
                                                               Text="arg" />
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TakesArgument}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                                <TextBlock DockPanel.Dock="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           Text="{Binding ActionType}" />
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                    <TextBlock FontSize="11"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding Phrases}" />
                                                </StackPanel>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty-state message when the filter matches nothing. -->
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontStyle="Italic"
                                           Text="No commands match your search.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CommandsView.IsEmpty}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                    <Button Width="120"
                                            Content="New command"
                                            Command="{Binding NewVoiceCommandCommand}" />
                                    <Button Width="88"
                                            Margin="8,0,0,0"
                                            Content="Reload"
                                            Command="{Binding ReloadCommandsCommand}" />
                                    <Button Width="160"
                                            Margin="8,0,0,0"
                                            Content="Open commands folder"
                                            Command="{Binding OpenCommandsFolderCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationError}" />
                </StackPanel>

                <!-- Dictionary (technical terms) page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Dictionary">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Technical dictionary" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Names and jargon the AI must never alter — inserted into every prompt via the {{TechnicalDictionary}} variable." />

                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                        <TextBox Width="240"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding NewDictionaryTerm, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Width="88"
                                Margin="8,0,0,0"
                                Content="Add"
                                Command="{Binding AddDictionaryTermCommand}" />
                    </StackPanel>

                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding DictionaryTerms}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,4" MaxWidth="340" HorizontalAlignment="Left">
                                    <Button DockPanel.Dock="Right"
                                            Width="66"
                                            Content="Remove"
                                            Command="{Binding DataContext.RemoveDictionaryTermCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <TextBlock Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding}" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationError}" />
                </StackPanel>

                <!-- Replacements (find-and-replace dictionary) page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Replacements">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Replacement dictionary" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Fix words the speech engine reliably mishears — names, acronyms and jargon. Each rule rewrites every match in the transcript before AI enhancement (e.g. Marco → Marko), so corrections apply even with the LLM off." />

                    <Button Width="120"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            Content="Add replacement"
                            Command="{Binding AddReplacementRuleCommand}" />

                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding ReplacementRules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,8" MaxWidth="560" HorizontalAlignment="Left">
                                    <Button DockPanel.Dock="Right"
                                            Width="66"
                                            VerticalAlignment="Center"
                                            Content="Remove"
                                            Command="{Binding DataContext.RemoveReplacementRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Width="180"
                                                     VerticalContentAlignment="Center"
                                                     Text="{Binding From, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Margin="8,0,8,0"
                                                       VerticalAlignment="Center"
                                                       Text="→" />
                                            <TextBox Width="180"
                                                     VerticalContentAlignment="Center"
                                                     Text="{Binding To, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                            <CheckBox Content="Whole word" IsChecked="{Binding WholeWord}" />
                                            <CheckBox Margin="16,0,0,0" Content="Case-sensitive" IsChecked="{Binding CaseSensitive}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Prompt modes can reference the pairs via the {{ReplacementDictionary}} variable so enhancement will not reverse them." />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationError}" />
                </StackPanel>

                <!-- Rules (per-application prompt mode) page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Rules">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Application rules" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Pick a prompt mode automatically from the app you dictate into. Process name without .exe (e.g. OUTLOOK, devenv); the first matching rule wins, otherwise the active mode applies." />

                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding ApplicationRules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                    <TextBox Width="160"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Width="150"
                                              Margin="8,0,0,0"
                                              ItemsSource="{Binding DataContext.PromptModeNames, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              SelectedItem="{Binding PromptMode}" />
                                    <Button Width="66"
                                            Margin="8,0,0,0"
                                            Content="Remove"
                                            Command="{Binding DataContext.RemoveApplicationRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Width="88"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Content="Add rule"
                            Command="{Binding AddApplicationRuleCommand}" />
                </StackPanel>

                <!-- History page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="History">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="History" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Only the delivered final text is stored, locally — never audio or raw transcripts." />

                    <CheckBox Margin="0,12,0,0"
                              Content="Keep a history of dictated text"
                              IsChecked="{Binding HistoryEnabled}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Max entries" />
                    <TextBox Width="80"
                             HorizontalAlignment="Left"
                             Text="{Binding HistoryMaxEntries, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               Text="Oldest entries are removed once the cap is exceeded. Must be at least 1." />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationError}" />
                </StackPanel>

                <!-- Pricing (cost estimation rates) page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Pricing">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Pricing" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Rates used to estimate costs on the Cost Dashboard. Enter what your provider charges; changes apply to new dictations only." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Speech price per minute" />
                    <TextBox Width="120"
                             HorizontalAlignment="Left"
                             Text="{Binding PricingSpeechPerMinute, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="LLM price per 1M prompt tokens" />
                    <TextBox Width="120"
                             HorizontalAlignment="Left"
                             Text="{Binding PricingLlmPromptPer1M, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="LLM price per 1M completion tokens" />
                    <TextBox Width="120"
                             HorizontalAlignment="Left"
                             Text="{Binding PricingLlmCompletionPer1M, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Currency" />
                    <TextBox Width="80"
                             HorizontalAlignment="Left"
                             Text="{Binding PricingCurrency, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationError}" />
                </StackPanel>

                <!-- Backup (import/export) page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Backup">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Backup" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Move your configuration between machines. API keys are excluded from settings exports unless you opt in; imports are validated and confirmed before they apply." />

                    <TextBlock Margin="0,16,0,4" FontWeight="SemiBold" Text="Settings" />
                    <StackPanel Orientation="Horizontal">
                        <Button Width="140"
                                Content="Export settings…"
                                Command="{Binding ExportSettingsCommand}" />
                        <Button Width="140"
                                Margin="8,0,0,0"
                                Content="Import settings…"
                                Command="{Binding ImportSettingsCommand}" />
                    </StackPanel>
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               TextWrapping="Wrap"
                               Text="Import understands current and older (pre-M7) settings files. The imported settings apply immediately — no restart needed." />

                    <TextBlock Margin="0,16,0,4" FontWeight="SemiBold" Text="Prompts" />
                    <StackPanel Orientation="Horizontal">
                        <Button Width="140"
                                Content="Export prompts…"
                                Command="{Binding ExportPromptsCommand}" />
                        <Button Width="140"
                                Margin="8,0,0,0"
                                Content="Import prompts…"
                                Command="{Binding ImportPromptsCommand}" />
                    </StackPanel>
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               TextWrapping="Wrap"
                               Text="Exports the prompts folder as a .zip; import asks before overwriting existing files." />

                    <TextBlock Margin="0,16,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding BackupStatus}" />
                </StackPanel>

                <!-- Diagnostics page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource SectionPage}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Diagnostics">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Diagnostics" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="About" />
                    <TextBlock Text="{Binding AppVersion, StringFormat=DictateFlow {0}}" />
                    <TextBlock Text="{Binding RuntimeVersion}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Data locations" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Margin="0,0,8,4"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding SettingsFilePath}"
                                   Text="{Binding SettingsFilePath}" />
                        <Button Grid.Row="0" Grid.Column="1"
                                Width="88"
                                Margin="0,0,0,4"
                                Content="Open folder"
                                Command="{Binding OpenFolderCommand}"
                                CommandParameter="{Binding RootDirectory}" />

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Margin="0,0,8,4"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding LogsDirectory}"
                                   Text="{Binding LogsDirectory}" />
                        <Button Grid.Row="1" Grid.Column="1"
                                Width="88"
                                Margin="0,0,0,4"
                                Content="Open folder"
                                Command="{Binding OpenFolderCommand}"
                                CommandParameter="{Binding LogsDirectory}" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Margin="0,0,8,4"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding PromptsDirectoryPath}"
                                   Text="{Binding PromptsDirectoryPath}" />
                        <Button Grid.Row="2" Grid.Column="1"
                                Width="88"
                                Margin="0,0,0,4"
                                Content="Open folder"
                                Command="{Binding OpenFolderCommand}"
                                CommandParameter="{Binding PromptsDirectoryPath}" />
                    </Grid>

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Log level" />
                    <ComboBox Width="160"
                              HorizontalAlignment="Left"
                              ItemsSource="{Binding LogLevels}"
                              SelectedItem="{Binding SelectedLogLevel}" />
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               Text="Debug writes per-dictation latency details. Saved with Save; takes effect after a restart." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Recent log (last 100 lines)" />
                    <Button Width="88"
                            HorizontalAlignment="Left"
                            Content="Refresh"
                            Command="{Binding RefreshLogTailCommand}" />
                    <TextBox Height="140"
                             Margin="0,8,0,0"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="11"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding LogTail, Mode=OneWay}" />

                    <Button Width="140"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            Content="Copy diagnostics"
                            Command="{Binding CopyDiagnosticsCommand}" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding DiagnosticsStatus}" />
                </StackPanel>
            </Grid>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="1"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Margin="0,8,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="96"
                        Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButton}"
                        IsDefault="True"
                        Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource FluentIcon}" Width="15" Height="15" Data="{StaticResource Icon.Save}" />
                        <AccessText Margin="7,0,0,0" VerticalAlignment="Center" Text="_Save" />
                    </StackPanel>
                </Button>
                <Button Width="88"
                        Content="_Cancel"
                        IsCancel="True"
                        Command="{Binding CancelCommand}" />
            </StackPanel>
            <!-- Soft save confirmation; auto-clears after a few seconds (SettingsViewModel). -->
            <TextBlock VerticalAlignment="Center"
                       Foreground="{StaticResource AccentBrush}"
                       FontWeight="SemiBold"
                       Text="{Binding SaveStatus}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Opacity" Value="1" />
                        <Style.Triggers>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter Property="Opacity" Value="0" />
                            </Trigger>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Opacity" Value="0" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>
