<Window x:Class="DictateFlow.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DictateFlow.App.Controls"
        Title="DictateFlow Settings"
        Width="640"
        Height="440"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ListBox Grid.Row="0"
                 Grid.Column="0"
                 Margin="0,0,8,0"
                 ItemsSource="{Binding Sections}"
                 SelectedItem="{Binding SelectedSection}" />

        <Border Grid.Row="0"
                Grid.Column="1"
                BorderBrush="{x:Static SystemColors.ActiveBorderBrush}"
                BorderThickness="1"
                Padding="16">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- General / Recording page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="General">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Recording" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Mode" />
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Push-to-talk (hold the hotkey)"
                                     GroupName="RecordingMode"
                                     IsChecked="{Binding IsPushToTalk}" />
                        <RadioButton Margin="16,0,0,0"
                                     Content="Toggle (press to start/stop)"
                                     GroupName="RecordingMode"
                                     IsChecked="{Binding IsToggle}" />
                    </StackPanel>

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Hotkey" />
                    <TextBox x:Name="HotkeyBox"
                             Width="200"
                             HorizontalAlignment="Left"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="False"
                             Text="{Binding Hotkey, Mode=OneWay}"
                             PreviewKeyDown="OnHotkeyBoxPreviewKeyDown" />
                    <TextBlock Foreground="{x:Static SystemColors.GrayTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               Text="Click the box and press the desired key combination." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Microphone" />
                    <ComboBox Width="280"
                              HorizontalAlignment="Left"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding Microphones}"
                              SelectedItem="{Binding SelectedMicrophone}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Silence timeout (seconds)" />
                    <TextBox Width="80"
                             HorizontalAlignment="Left"
                             Text="{Binding SilenceTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="Firebrick"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationError}" />
                </StackPanel>

                <!-- Speech (transcription provider) page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Speech">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Speech recognition" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{x:Static SystemColors.GrayTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Azure AI Foundry transcription. Leave the endpoint empty to use the built-in mock provider." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Endpoint" />
                    <TextBox Width="340"
                             HorizontalAlignment="Left"
                             Text="{Binding SpeechEndpoint, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="API key" />
                    <PasswordBox Width="340"
                                 HorizontalAlignment="Left"
                                 controls:PasswordBoxHelper.BoundPassword="{Binding SpeechApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Deployment name" />
                    <TextBox Width="200"
                             HorizontalAlignment="Left"
                             Text="{Binding SpeechDeploymentName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Language" />
                    <TextBox Width="120"
                             HorizontalAlignment="Left"
                             Text="{Binding SpeechLanguage, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Timeout (seconds)" />
                    <TextBox Width="80"
                             HorizontalAlignment="Left"
                             Text="{Binding SpeechTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Width="140"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            Content="Test connection"
                            Command="{Binding TestConnectionCommand}" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding SpeechTestResult}" />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="Firebrick"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationError}" />
                </StackPanel>

                <!-- LLM (enhancement provider) page -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="LLM">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="LLM enhancement" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{x:Static SystemColors.GrayTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Azure AI Foundry chat completions. Leave the endpoint empty to use the built-in mock provider." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Endpoint" />
                    <TextBox Width="340"
                             HorizontalAlignment="Left"
                             Text="{Binding LlmEndpoint, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="API key" />
                    <PasswordBox Width="340"
                                 HorizontalAlignment="Left"
                                 controls:PasswordBoxHelper.BoundPassword="{Binding LlmApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Deployment name" />
                    <TextBox Width="200"
                             HorizontalAlignment="Left"
                             Text="{Binding LlmDeploymentName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Temperature (0–2)" />
                    <StackPanel Orientation="Horizontal">
                        <Slider Width="220"
                                VerticalAlignment="Center"
                                Minimum="0"
                                Maximum="2"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding LlmTemperature}" />
                        <TextBox Width="60"
                                 Margin="8,0,0,0"
                                 Text="{Binding LlmTemperature, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <TextBlock Foreground="{x:Static SystemColors.GrayTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               Text="Default for modes without their own temperature." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Max tokens" />
                    <TextBox Width="80"
                             HorizontalAlignment="Left"
                             Text="{Binding LlmMaxTokens, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Timeout (seconds)" />
                    <TextBox Width="80"
                             HorizontalAlignment="Left"
                             Text="{Binding LlmTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Width="140"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            Content="Test connection"
                            Command="{Binding TestLlmConnectionCommand}" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding LlmTestResult}" />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="Firebrick"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationError}" />
                </StackPanel>

                <!-- Prompts page: loaded modes, active-mode selector, and the Prompt Tester -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Prompts">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Prompt modes" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{x:Static SystemColors.GrayTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="One JSON file per mode in the prompts folder. Edit or add files, then Reload to pick them up." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Active mode" />
                    <ComboBox Width="220"
                              HorizontalAlignment="Left"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding PromptModes}"
                              SelectedItem="{Binding SelectedPromptMode}" />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Loaded modes" />
                    <ItemsControl ItemsSource="{Binding PromptModes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                    <TextBlock Margin="8,0,0,0"
                                               Foreground="{x:Static SystemColors.GrayTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding Description}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <Button Width="88"
                                Content="Reload"
                                Command="{Binding ReloadPromptsCommand}" />
                        <Button Width="140"
                                Margin="8,0,0,0"
                                Content="Open prompts folder"
                                Command="{Binding OpenPromptsFolderCommand}" />
                    </StackPanel>

                    <Separator Margin="0,16,0,8" />

                    <TextBlock FontSize="15"
                               FontWeight="SemiBold"
                               Text="Prompt Tester" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{x:Static SystemColors.GrayTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Paste a transcript and run it through the resolver and LLM — no recording needed." />

                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Transcript" />
                    <TextBox Height="70"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding TesterTranscript, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <ComboBox Width="180"
                                  VerticalAlignment="Center"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{Binding PromptModes}"
                                  SelectedItem="{Binding TesterMode}" />
                        <Button Width="88"
                                Margin="8,0,0,0"
                                Content="Run"
                                Command="{Binding RunTesterCommand}" />
                        <Button Width="88"
                                Margin="8,0,0,0"
                                Content="Cancel"
                                Command="{Binding RunTesterCancelCommand}" />
                    </StackPanel>

                    <Expander Margin="0,8,0,0" Header="Resolved system prompt">
                        <TextBox MaxHeight="120"
                                 Margin="0,4,0,0"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding TesterResolvedPrompt, Mode=OneWay}" />
                    </Expander>

                    <TextBlock Margin="0,8,0,4" FontWeight="SemiBold" Text="Result" />
                    <TextBox Height="90"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding TesterResult, Mode=OneWay}" />
                </StackPanel>

                <!-- Placeholder for sections that arrive in later milestones -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="General">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Speech">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="LLM">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Prompts">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="{Binding SelectedSection}" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{x:Static SystemColors.GrayTextBrush}"
                               TextWrapping="Wrap"
                               Text="Settings for this section will be added in a later milestone." />
                </StackPanel>
            </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="88"
                    Margin="0,0,8,0"
                    Content="Save"
                    IsDefault="True"
                    Command="{Binding SaveCommand}" />
            <Button Width="88"
                    Content="Cancel"
                    IsCancel="True"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>
