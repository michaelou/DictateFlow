<Window x:Class="DictateFlow.App.Views.CostDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DictateFlow.App.Controls"
        Background="{DynamicResource WindowBackgroundBrush}"
        Title="DictateFlow Usage &amp; Cost"
        Width="800"
        Height="600"
        MinWidth="640"
        MinHeight="480"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <controls:CostMagnitudeBrushConverter x:Key="CostMagnitude" />
        <controls:FractionWidthConverter x:Key="FractionWidth" />

        <!-- One label→value metric row inside a card. -->
        <Style x:Key="MetricRow" TargetType="{x:Type Grid}">
            <Setter Property="Margin" Value="0,3,0,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource FluentIcon}" Width="16" Height="16" Data="{StaticResource Icon.Refresh}" />
                    <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="Refresh" />
                </StackPanel>
            </Button>
            <TextBlock VerticalAlignment="Center"
                       FontSize="{StaticResource FontSizeTitle}"
                       FontWeight="SemiBold"
                       Text="Usage &amp; estimated cost" />
        </DockPanel>

        <!-- Today / This month / Lifetime stat cards -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Periods}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Margin="6" Style="{StaticResource Card}">
                            <StackPanel>
                                <!-- Gradient header band -->
                                <Border Background="{StaticResource AccentGradientBrush}"
                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                        Padding="10,6">
                                    <TextBlock Foreground="#FFFFFFFF"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               FontWeight="SemiBold"
                                               Text="{Binding Title}" />
                                </Border>

                                <!-- Hero total, counted up on load / refresh -->
                                <TextBlock Margin="0,14,0,0"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="Total estimated cost" />
                                <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                    <TextBlock FontSize="{StaticResource FontSizeHero}"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding TotalCostValue, Converter={StaticResource CostMagnitude}}"
                                               controls:CountUp.To="{Binding TotalCostValue}"
                                               controls:CountUp.Format="0.0000" />
                                    <TextBlock VerticalAlignment="Bottom"
                                               Margin="6,0,0,6"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="{Binding Currency}" />
                                </StackPanel>

                                <!-- Speech vs LLM cost split -->
                                <Border x:Name="barTrack"
                                        Height="8"
                                        Margin="0,12,0,0"
                                        Background="{StaticResource ControlBackgroundBrush}"
                                        CornerRadius="{StaticResource PillCornerRadius}"
                                        ClipToBounds="True">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource AccentBrush}">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource FractionWidth}">
                                                    <Binding Path="SpeechCostFraction" />
                                                    <Binding Path="ActualWidth" ElementName="barTrack" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                        <Border Background="{StaticResource AccentSecondaryBrush}">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource FractionWidth}">
                                                    <Binding Path="LlmCostFraction" />
                                                    <Binding Path="ActualWidth" ElementName="barTrack" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" />
                                    <TextBlock Margin="5,0,12,0"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Speech" />
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{StaticResource AccentSecondaryBrush}" />
                                    <TextBlock Margin="5,0,0,0"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="LLM" />
                                </StackPanel>

                                <!-- Words -->
                                <Grid Style="{StaticResource MetricRow}" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource FluentIcon}" Width="14" Height="14" Fill="{StaticResource SecondaryTextBrush}" Data="{StaticResource Icon.Document}" />
                                        <TextBlock Margin="7,0,0,0" Text="Words dictated" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               FontWeight="SemiBold"
                                               controls:CountUp.To="{Binding WordsValue}"
                                               controls:CountUp.Format="N0" />
                                </Grid>

                                <!-- Speech -->
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Path Style="{StaticResource FluentIcon}" Width="14" Height="14" Fill="{StaticResource AccentBrush}" Data="{StaticResource Icon.Mic}" />
                                    <TextBlock Margin="7,0,0,0" FontWeight="SemiBold" Text="Speech" />
                                </StackPanel>
                                <Grid Style="{StaticResource MetricRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Requests" />
                                    <TextBlock Grid.Column="1" Text="{Binding SpeechRequests}" />
                                </Grid>
                                <Grid Style="{StaticResource MetricRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Minutes" />
                                    <TextBlock Grid.Column="1" Text="{Binding SpeechMinutes}" />
                                </Grid>
                                <Grid Style="{StaticResource MetricRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Cost" />
                                    <TextBlock Grid.Column="1" Text="{Binding SpeechCost}" />
                                </Grid>

                                <!-- LLM -->
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Path Style="{StaticResource FluentIcon}" Width="14" Height="14" Fill="{StaticResource AccentSecondaryBrush}" Data="{StaticResource Icon.Sparkle}" />
                                    <TextBlock Margin="7,0,0,0" FontWeight="SemiBold" Text="LLM" />
                                </StackPanel>
                                <Grid Style="{StaticResource MetricRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Requests" />
                                    <TextBlock Grid.Column="1" Text="{Binding LlmRequests}" />
                                </Grid>
                                <Grid Style="{StaticResource MetricRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Prompt / completion" />
                                    <TextBlock Grid.Column="1">
                                        <Run Text="{Binding PromptTokens, Mode=OneWay}" /><Run Text=" / " /><Run Text="{Binding CompletionTokens, Mode=OneWay}" />
                                    </TextBlock>
                                </Grid>
                                <Grid Style="{StaticResource MetricRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Cost" />
                                    <TextBlock Grid.Column="1" Text="{Binding LlmCost}" />
                                </Grid>
                            </StackPanel>
                        </ContentControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   TextWrapping="Wrap"
                   Text="{Binding StatusMessage}" />
    </Grid>
</Window>
