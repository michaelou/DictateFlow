<Window x:Class="DictateFlow.App.Views.PromptModeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Background="{DynamicResource WindowBackgroundBrush}"
        Width="520"
        Height="480"
        MinWidth="400"
        MinHeight="360"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontWeight="SemiBold" Text="Name" />
            <TextBox Margin="0,4,0,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock FontWeight="SemiBold" Text="Description" />
            <TextBox Margin="0,4,0,0" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <CheckBox Content="Send through LLM" IsChecked="{Binding LlmEnabled}" />
            <TextBlock Margin="0,2,0,0"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       TextWrapping="Wrap"
                       Text="When off, dictations using this mode deliver the raw transcript as-is — no AI enhancement, no LLM cost." />
        </StackPanel>

        <!-- System prompt and temperature only matter when the LLM runs -->
        <DockPanel Grid.Row="3" Margin="0,10,0,0" IsEnabled="{Binding LlmEnabled}">
            <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Text="System prompt" />
            <TextBlock DockPanel.Dock="Top"
                       Margin="0,2,0,4"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       TextWrapping="Wrap"
                       Text="Supports {{Transcript}}, {{ApplicationName}}, {{Mode}}, {{CurrentDate}} and {{TechnicalDictionary}}." />
            <TextBox AcceptsReturn="True"
                     FontFamily="Consolas"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <StackPanel Grid.Row="4"
                    Margin="0,10,0,0"
                    Orientation="Horizontal"
                    IsEnabled="{Binding LlmEnabled}">
            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Temperature" />
            <TextBox Width="80"
                     Margin="8,0,0,0"
                     Text="{Binding TemperatureText, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Margin="8,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="Empty = provider default (0–2)" />
        </StackPanel>

        <TextBlock Grid.Row="5"
                   Margin="0,8,0,0"
                   Foreground="{StaticResource ErrorBrush}"
                   TextWrapping="Wrap"
                   Text="{Binding ValidationError}" />

        <StackPanel Grid.Row="6"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="88"
                    Margin="0,0,8,0"
                    Content="Save"
                    IsDefault="True"
                    Command="{Binding SaveCommand}" />
            <Button Width="88"
                    Content="Cancel"
                    IsCancel="True"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>
