<Window x:Class="DictateFlow.App.Views.CloudRecordingToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DictateFlow — New Recording"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Border MaxWidth="360"
            Padding="16,14"
            Background="{DynamicResource SurfaceElevatedBrush}"
            BorderBrush="{DynamicResource SurfaceBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Cursor="Hand"
            MouseLeftButtonUp="OnBodyClicked">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.35" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Top"
                       Margin="0,0,10,0"
                       FontSize="20"
                       Text="🎙" />

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock FontWeight="SemiBold"
                           FontSize="14"
                           Text="DictateFlow" />
                <TextBlock Margin="0,3,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding Message, RelativeSource={RelativeSource AncestorType=Window}}" />
                <TextBlock Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Text="Click to review" />
            </StackPanel>

            <Button Grid.Column="2"
                    Width="24"
                    Height="24"
                    Margin="8,-4,-4,0"
                    VerticalAlignment="Top"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="Dismiss"
                    Click="OnDismissClicked">
                <TextBlock FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Text="✕" />
            </Button>
        </Grid>
    </Border>
</Window>
