<Window x:Class="DictateFlow.App.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DictateFlow.App.Controls"
        Background="{DynamicResource WindowBackgroundBrush}"
        Title="DictateFlow History"
        Width="640"
        Height="480"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <controls:ModeColorConverter x:Key="ModeColor" />

        <!-- Each history row is a floating, hover-lifting card (foundation elevation + motion). -->
        <Style x:Key="HistoryCard" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="11,9" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="card"
                                Background="{StaticResource SurfaceElevatedBrush}"
                                BorderBrush="{StaticResource SurfaceBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="lift" Y="0" />
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect x:Name="shadow"
                                                  Color="#FF000000"
                                                  BlurRadius="10"
                                                  ShadowDepth="1"
                                                  Direction="270"
                                                  Opacity="0.35" />
                            </Border.Effect>
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Fade each card in on load — also fires when the filter repopulates the list. -->
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.22" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="card" Property="Background" Value="{StaticResource SurfaceElevatedHoverBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="lift" Storyboard.TargetProperty="Y" To="-2" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="BlurRadius" To="20" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="ShadowDepth" To="4" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="lift" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="BlurRadius" To="10" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="ShadowDepth" To="1" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="Opacity" To="0.35" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="card" Property="Background" Value="{StaticResource SurfaceElevatedHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Per-row action buttons: hidden until the row is hovered or selected. -->
        <Style x:Key="RowActions" TargetType="{x:Type StackPanel}">
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar: search field with a leading glyph + refresh / clear icon buttons -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right"
                    Width="36"
                    Height="36"
                    Margin="8,0,0,0"
                    Style="{StaticResource IconButton}"
                    ToolTip="Clear all"
                    Command="{Binding ClearAllCommand}">
                <Path Style="{StaticResource FluentIcon}" Width="18" Height="18" Data="{StaticResource Icon.Broom}" />
            </Button>
            <Button DockPanel.Dock="Right"
                    Width="36"
                    Height="36"
                    Margin="8,0,0,0"
                    Style="{StaticResource IconButton}"
                    ToolTip="Refresh"
                    Command="{Binding RefreshCommand}">
                <Path Style="{StaticResource FluentIcon}" Width="18" Height="18" Data="{StaticResource Icon.Refresh}" />
            </Button>

            <Border Background="{StaticResource ControlBackgroundBrush}"
                    BorderBrush="{StaticResource BorderStrongBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="8,0"
                    Height="36">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="0"
                          Style="{StaticResource FluentIcon}"
                          Width="15"
                          Height="15"
                          Margin="0,0,8,0"
                          Fill="{StaticResource SecondaryTextBrush}"
                          Data="{StaticResource Icon.Search}" />
                    <Grid Grid.Column="1">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   IsHitTestVisible="False"
                                   Text="Search history…">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="SearchBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search the dictation history" />
                    </Grid>
                </Grid>
            </Border>
        </DockPanel>

        <!-- Entry list: newest first, hover-lifting cards with per-entry Copy and Delete -->
        <ListBox Grid.Row="1"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalContentAlignment="Stretch"
                 ItemContainerStyle="{StaticResource HistoryCard}"
                 ItemsSource="{Binding Entries}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectedItem="{Binding SelectedEntry}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="{Binding TimestampText}" />
                                <Border Margin="8,0,0,0"
                                        Padding="8,1"
                                        VerticalAlignment="Center"
                                        Background="{Binding ModeName, Converter={StaticResource ModeColor}, ConverterParameter=bg}"
                                        CornerRadius="{StaticResource PillCornerRadius}">
                                    <TextBlock FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding ModeName, Converter={StaticResource ModeColor}, ConverterParameter=fg}"
                                               Text="{Binding ModeName}" />
                                </Border>
                            </StackPanel>
                            <TextBlock FontSize="{StaticResource FontSizeBody}"
                                       Text="{Binding Preview}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding HasRawText, Converter={StaticResource BoolToVisibility}}">
                                <Run Text="raw:" />
                                <Run Text="{Binding RawPreview, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Style="{StaticResource RowActions}">
                            <Button Width="30"
                                    Height="30"
                                    Style="{StaticResource IconButton}"
                                    ToolTip="Copy"
                                    Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}">
                                <Grid>
                                    <Path x:Name="copyGlyph" Style="{StaticResource FluentIcon}" Data="{StaticResource Icon.Copy}" />
                                    <Path x:Name="checkGlyph"
                                          Style="{StaticResource FluentIcon}"
                                          Opacity="0"
                                          Fill="{StaticResource SuccessBrush}"
                                          Data="{StaticResource Icon.Checkmark}" />
                                </Grid>
                                <Button.Triggers>
                                    <!-- Flash a green checkmark for ~1s to confirm the copy. -->
                                    <EventTrigger RoutedEvent="Button.Click">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="checkGlyph" Storyboard.TargetProperty="Opacity">
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                                    <LinearDoubleKeyFrame KeyTime="0:0:0.12" Value="1" />
                                                    <LinearDoubleKeyFrame KeyTime="0:0:1" Value="1" />
                                                    <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0" />
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="copyGlyph" Storyboard.TargetProperty="Opacity">
                                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                                    <LinearDoubleKeyFrame KeyTime="0:0:0.12" Value="0" />
                                                    <LinearDoubleKeyFrame KeyTime="0:0:1" Value="0" />
                                                    <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="1" />
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Button.Triggers>
                            </Button>
                            <Button Width="30"
                                    Height="30"
                                    Margin="4,0,0,0"
                                    Style="{StaticResource IconButton}"
                                    ToolTip="Delete"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}">
                                <Path Style="{StaticResource FluentIcon}" Data="{StaticResource Icon.Delete}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Detail pane: final text next to the raw transcript, plus the prompt mode -->
        <Expander Grid.Row="2"
                  Margin="0,10,0,0"
                  Header="Detail"
                  IsExpanded="True">
            <Grid Margin="0,6,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Grid.ColumnSpan="3"
                           Margin="0,0,0,6"
                           Foreground="{StaticResource SecondaryTextBrush}">
                    <Run Text="Prompt mode:" />
                    <Run FontWeight="SemiBold" Text="{Binding SelectedEntry.ModeName, Mode=OneWay}" />
                </TextBlock>

                <DockPanel Grid.Row="1" Grid.Column="0">
                    <Button DockPanel.Dock="Right"
                            Width="26"
                            Height="26"
                            Style="{StaticResource IconButton}"
                            ToolTip="Copy final text"
                            Command="{Binding CopyCommand}"
                            CommandParameter="{Binding SelectedEntry}">
                        <Path Style="{StaticResource FluentIcon}" Width="14" Height="14" Data="{StaticResource Icon.Copy}" />
                    </Button>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="Final text" />
                </DockPanel>
                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="Raw transcript" />

                <TextBox Grid.Row="2"
                         Grid.Column="0"
                         Height="90"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         Text="{Binding SelectedEntry.FullText, Mode=OneWay}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
                <TextBox Grid.Row="2"
                         Grid.Column="2"
                         Height="90"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         Text="{Binding SelectedEntry.RawText, Mode=OneWay}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Expander>

        <TextBlock Grid.Row="3"
                   Margin="0,8,0,0"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   Text="{Binding StatusMessage}" />
    </Grid>
</Window>
