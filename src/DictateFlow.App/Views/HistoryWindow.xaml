<Window x:Class="DictateFlow.App.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource WindowBackgroundBrush}"
        Title="DictateFlow History"
        Width="640"
        Height="480"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar: search + clear all -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right"
                    Width="32"
                    Height="32"
                    Margin="8,0,0,0"
                    Padding="6"
                    ToolTip="Clear all"
                    Command="{Binding ClearAllCommand}">
                <Image Source="/Resources/clear.png" Stretch="Uniform" />
            </Button>
            <Button DockPanel.Dock="Right"
                    Width="32"
                    Height="32"
                    Margin="8,0,0,0"
                    Padding="6"
                    ToolTip="Refresh"
                    Command="{Binding RefreshCommand}">
                <Image Source="/Resources/refresh.png" Stretch="Uniform" />
            </Button>
            <TextBox VerticalContentAlignment="Center"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Search the dictation history" />
        </DockPanel>

        <!-- Entry list: newest first, per-entry Copy and Delete -->
        <ListBox Grid.Row="1"
                 HorizontalContentAlignment="Stretch"
                 ItemsSource="{Binding Entries}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectedItem="{Binding SelectedEntry}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="0,2">
                        <StackPanel DockPanel.Dock="Right"
                                    Margin="8,0,0,0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Width="28"
                                    Height="28"
                                    Padding="5"
                                    ToolTip="Copy"
                                    Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}">
                                <Image Source="/Resources/copy.png" Stretch="Uniform" />
                            </Button>
                            <Button Width="28"
                                    Height="28"
                                    Margin="4,0,0,0"
                                    Padding="5"
                                    ToolTip="Delete"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}">
                                <Image Source="/Resources/delete.png" Stretch="Uniform" />
                            </Button>
                        </StackPanel>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="{Binding TimestampText}" />
                                <Border Margin="8,0,0,0"
                                        Padding="5,0"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource SecondaryTextBrush}"
                                        CornerRadius="3"
                                        Opacity="0.85">
                                    <TextBlock FontSize="10"
                                               Foreground="{DynamicResource WindowBackgroundBrush}"
                                               Text="{Binding ModeName}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding Preview}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="0,1,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding HasRawText, Converter={StaticResource BoolToVisibility}}">
                                <Run Text="raw:" />
                                <Run Text="{Binding RawPreview, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Detail pane: final text next to the raw transcript, plus the prompt mode -->
        <Expander Grid.Row="2"
                  Margin="0,8,0,0"
                  Header="Detail"
                  IsExpanded="True">
            <Grid Margin="0,4,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Grid.ColumnSpan="3"
                           Margin="0,0,0,4"
                           Foreground="{StaticResource SecondaryTextBrush}">
                    <Run Text="Prompt mode:" />
                    <Run FontWeight="SemiBold" Text="{Binding SelectedEntry.ModeName, Mode=OneWay}" />
                </TextBlock>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           FontSize="11"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="Final text" />
                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           FontSize="11"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="Raw transcript" />

                <TextBox Grid.Row="2"
                         Grid.Column="0"
                         Height="90"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         Text="{Binding SelectedEntry.FullText, Mode=OneWay}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
                <TextBox Grid.Row="2"
                         Grid.Column="2"
                         Height="90"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         Text="{Binding SelectedEntry.RawText, Mode=OneWay}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Expander>

        <TextBlock Grid.Row="3"
                   Margin="0,6,0,0"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   Text="{Binding StatusMessage}" />
    </Grid>
</Window>
