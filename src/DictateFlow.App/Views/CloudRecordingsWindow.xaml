<Window x:Class="DictateFlow.App.Views.CloudRecordingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource WindowBackgroundBrush}"
        Title="DictateFlow — Cloud Recordings"
        Width="1200"
        Height="740"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- Per-row action buttons: hidden until the row is hovered or selected. -->
        <Style x:Key="RowActions" TargetType="{x:Type StackPanel}">
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar: check for new recordings + refresh -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right"
                    Width="36"
                    Height="36"
                    Margin="8,0,0,0"
                    Style="{StaticResource IconButton}"
                    ToolTip="Refresh the list"
                    Command="{Binding RefreshCommand}">
                <Path Style="{StaticResource FluentIcon}" Width="18" Height="18" Data="{StaticResource Icon.Refresh}" />
            </Button>

            <!-- Enhancement mode applied to each new recording after transcription. -->
            <StackPanel DockPanel.Dock="Right"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="Enhance with" />
                <ComboBox Width="180"
                          VerticalAlignment="Center"
                          ToolTip="LLM prompt mode applied to each recording after transcription"
                          ItemsSource="{Binding PromptModeOptions}"
                          SelectedItem="{Binding SelectedPromptMode}" />
            </StackPanel>

            <Button Height="36"
                    HorizontalAlignment="Left"
                    Padding="14,0"
                    Style="{StaticResource PrimaryButton}"
                    ToolTip="Check the Azure container for new recordings and transcribe them"
                    Command="{Binding CheckNowCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource FluentIcon}"
                          Width="16"
                          Height="16"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          Data="{StaticResource Icon.Download}" />
                    <TextBlock VerticalAlignment="Center" Text="Check for new recordings" />
                </StackPanel>
            </Button>
        </DockPanel>

        <!-- Indeterminate progress while a check or download runs. -->
        <ProgressBar Grid.Row="1"
                     Height="2"
                     Margin="0,0,0,8"
                     IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />

        <!-- Recording list: newest first, with per-row Play / Copy / Delete -->
        <ListBox Grid.Row="2"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalContentAlignment="Stretch"
                 ItemsSource="{Binding Entries}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectedItem="{Binding SelectedEntry}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="{Binding ShortName}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="{Binding TimestampText}" />
                                <TextBlock Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="{Binding DurationText}" />
                            </StackPanel>
                            <TextBlock FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{Binding Preview}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Style="{StaticResource RowActions}">
                            <Button Width="30"
                                    Height="30"
                                    Style="{StaticResource IconButton}"
                                    ToolTip="Play"
                                    Command="{Binding DataContext.PlayPauseCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}">
                                <TextBlock FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" Text="▶" />
                            </Button>
                            <Button Width="30"
                                    Height="30"
                                    Margin="4,0,0,0"
                                    Style="{StaticResource IconButton}"
                                    ToolTip="Copy transcript"
                                    Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}">
                                <Path Style="{StaticResource FluentIcon}" Data="{StaticResource Icon.Copy}" />
                            </Button>
                            <Button Width="30"
                                    Height="30"
                                    Margin="4,0,0,0"
                                    Style="{StaticResource IconButton}"
                                    ToolTip="Remove from list"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}">
                                <Path Style="{StaticResource FluentIcon}" Data="{StaticResource Icon.Delete}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Detail pane: the full transcript of the selected recording -->
        <Expander Grid.Row="3"
                  Margin="0,10,0,0"
                  Header="Transcript"
                  IsExpanded="True">
            <TextBox Height="90"
                     Margin="0,6,0,0"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     Text="{Binding SelectedEntry.FullText, Mode=OneWay}"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
        </Expander>

        <!-- Transport bar: play/pause, stop, seek slider and times for the loaded recording -->
        <Border Grid.Row="4"
                Margin="0,10,0,0"
                Padding="10,8"
                Background="{StaticResource SurfaceElevatedBrush}"
                BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Width="34"
                        Height="34"
                        Style="{StaticResource IconButton}"
                        ToolTip="Play / pause"
                        Command="{Binding TogglePlaybackCommand}">
                    <TextBlock FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="▶" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Text" Value="⏸" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
                <Button Grid.Column="1"
                        Width="34"
                        Height="34"
                        Margin="4,0,0,0"
                        Style="{StaticResource IconButton}"
                        ToolTip="Stop"
                        Command="{Binding StopCommand}">
                    <TextBlock FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" Text="⏹" />
                </Button>

                <TextBlock Grid.Column="2"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="{Binding PositionText}" />

                <Slider Grid.Column="3"
                        Margin="8,0,8,0"
                        VerticalAlignment="Center"
                        Minimum="0"
                        Maximum="{Binding DurationSeconds}"
                        Value="{Binding PositionSeconds, Mode=TwoWay}"
                        IsMoveToPointEnabled="True" />

                <TextBlock Grid.Column="4"
                           VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="{Binding DurationText}" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="5"
                   Margin="0,8,0,0"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   Text="{Binding StatusMessage}" />
    </Grid>
</Window>
